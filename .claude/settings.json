{
  "env": {
    "CLAUDE_CODE_MAX_RETRIES": "3",
    "API_TIMEOUT_MS": "30000"
  },
  "permissions": {
    "deny": [
      "Bash(**/.env)",
      "Read(**/.env)",
      "Write(**/.env)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark",
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true
  }
}
